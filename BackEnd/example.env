# ============================================================
#  BACKEND ENVIRONMENT — TEMPLATE
#  Copy this file to `.env` and fill in your real values.
#  `.env` is gitignored; never commit your real secrets.
# ============================================================

# CORS: comma-separated list of allowed origins, or * for any.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================
#  Supabase auth — pick ONE of the two depending on your project:
#    1. Legacy HS256 projects: set SUPABASE_JWT_SECRET
#       (Project Settings > API > JWT Secret).
#    2. Newer ES256 / asymmetric projects: set SUPABASE_URL to your
#       project URL (e.g. https://abcdefg.supabase.co). The backend
#       will fetch the public key from /auth/v1/.well-known/jwks.json
#       automatically.
#  Leave BOTH unset to disable auth verification (dev mode).
# ============================================================
SUPABASE_JWT_SECRET=
SUPABASE_URL=

# ============================================================
#  LLM / Script generation
#  Pick one of: HuggingFace router (TEXTGENERATION_*) or OpenRouter.
# ============================================================
TEXTGENERATION_MODEL=Qwen/Qwen3-Coder-Next:novita
TEXTGENERATION_HF_token=hf_your_huggingface_token_here
TEXTGENERATION_BASE_URL=https://router.huggingface.co/v1
OPENROUTER_API_KEY=

# ============================================================
#  ElevenLabs (English TTS) — supports up to 9 rotated keys.
# ============================================================
ELEVENLABS_API_KEY1=
ELEVENLABS_API_KEY2=
ELEVENLABS_API_KEY3=
ELEVENLABS_API_KEY4=

# ============================================================
#  Munsit (Arabic TTS) — up to 9 rotated keys.
# ============================================================
MUNSIT_API_KEY1=
MUNSIT_API_KEY2=
MUNSIT_API_KEY3=

# ============================================================
#  Cover art (HuggingFace inference)
# ============================================================
HF_TOKEN_coverArt=

# ============================================================
#  Cloudinary (asset storage)
# ============================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
